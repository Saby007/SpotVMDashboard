{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_generator": {
      "name": "bicep",
      "version": "0.39.26.7824",
      "templateHash": "11996774552237708280"
    }
  },
  "parameters": {
    "baseName": {
      "type": "string",
      "defaultValue": "spotvm-hdfc",
      "metadata": {
        "description": "Base resource name prefix"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region"
      }
    },
    "appServiceSkuName": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [
        "B1",
        "B2",
        "S1",
        "S2",
        "P1v3",
        "P2v3"
      ],
      "metadata": {
        "description": "App Service Plan SKU (B1 = Basic, S1 = Standard, P1v3 = Premium)"
      }
    },
    "tags": {
      "type": "object",
      "defaultValue": {},
      "metadata": {
        "description": "Resource tags"
      }
    }
  },
  "resources": [
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}-plan', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "kind": "linux",
      "sku": {
        "name": "[parameters('appServiceSkuName')]"
      },
      "properties": {
        "reserved": true
      }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[format('{0}-webapp', parameters('baseName'))]",
      "location": "[parameters('location')]",
      "tags": "[parameters('tags')]",
      "identity": {
        "type": "SystemAssigned"
      },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('baseName')))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "NODE|20-lts",
          "appCommandLine": "node server.js",
          "minTlsVersion": "1.2",
          "ftpsState": "Disabled",
          "http20Enabled": true,
          "alwaysOn": "[and(not(equals(parameters('appServiceSkuName'), 'B1')), not(equals(parameters('appServiceSkuName'), 'B2')))]",
          "appSettings": [
            {
              "name": "WEBSITE_NODE_DEFAULT_VERSION",
              "value": "~20"
            },
            {
              "name": "SCM_DO_BUILD_DURING_DEPLOYMENT",
              "value": "true"
            }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', format('{0}-plan', parameters('baseName')))]"
      ]
    }
  ],
  "outputs": {
    "webAppName": {
      "type": "string",
      "value": "[format('{0}-webapp', parameters('baseName'))]"
    },
    "webAppDefaultHostName": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', format('{0}-webapp', parameters('baseName'))), '2023-12-01').defaultHostName]"
    },
    "webAppPrincipalId": {
      "type": "string",
      "value": "[reference(resourceId('Microsoft.Web/sites', format('{0}-webapp', parameters('baseName'))), '2023-12-01', 'full').identity.principalId]"
    },
    "webAppResourceId": {
      "type": "string",
      "value": "[resourceId('Microsoft.Web/sites', format('{0}-webapp', parameters('baseName')))]"
    }
  }
}